# ─── Mode Aplikasi ────────────────────────────────────────────────────────────
# "inmemory" → pakai dummy data, tanpa DB (untuk development awal)
# "real"     → pakai PostgreSQL + Neo4j sungguhan
APP_MODE=real

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=virgo_talent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=12345

# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=12345678

# ─── ROC Criteria Ranking ─────────────────────────────────────────────────────
# Angka = urutan kepentingan (1 = paling penting)
# Ubah sesuai hasil konsultasi stakeholder — tidak perlu ganti kode
CRITERIA_RANK_SKILL=1
CRITERIA_RANK_PENGALAMAN=2
CRITERIA_RANK_LOKASI=3
CRITERIA_RANK_PREFERENSI_PROYEK=4
CRITERIA_RANK_KETERSEDIAAN=5

# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
